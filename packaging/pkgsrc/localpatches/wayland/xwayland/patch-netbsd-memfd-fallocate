$NetBSD$

Use Xwayland's unlinked runtime file instead of memfd_create(2) on NetBSD.
NetBSD 11 memfd descriptors can be sized successfully but mmap(2) returns
EINVAL for some rootless redirected-window pixmap sizes.  That leaves the
window at RedirectDrawNone, so Xwayland never creates or publishes its
Wayland surface.

Also fall back to ftruncate(2) when a runtime file type does not implement
posix_fallocate(2).  This keeps the anonymous-file helper usable on NetBSD
filesystems which reject preallocation but support ordinary sizing and
mapping.

--- hw/xwayland/xwayland-shm.c.orig
+++ hw/xwayland/xwayland-shm.c
@@ -135,1 +135,1 @@ os_create_anonymous_file(off_t size)
-#ifdef HAVE_MEMFD_CREATE
+#if defined(HAVE_MEMFD_CREATE) && !defined(__NetBSD__)
@@ -179,21 +179,25 @@ os_create_anonymous_file(off_t size)
     } while (ret == EINTR);
     OsReleaseSignals();
 
-    if (ret != 0) {
+    if (ret == 0)
+        return fd;
+
+    if (ret != EINVAL && ret != EOPNOTSUPP) {
         close(fd);
         errno = ret;
         return -1;
     }
-#else
+#endif
+
+    /* The descriptor supports sizing, but not preallocation. */
     do {
         ret = ftruncate(fd, size);
     } while (ret == -1 && errno == EINTR);
 
     if (ret < 0) {
         close(fd);
         return -1;
     }
-#endif
 
     return fd;
 }
