#!/bin/sh

set -eu

if [ "$#" -gt 1 ]; then
    echo "nixbench-session: usage: nixbench-session [--local]" >&2
    exit 2
fi

local_launch=0
case "${1-}" in
    --help)
        cat <<EOF
Usage: nixbench-session [--local]

Start the standalone NixBench desktop on the active NetBSD wsdisplay console.
Run it over SSH while the physical console is visible. The desktop starts
empty and takes over after preflight without an additional confirmation;
launch applications from the global Applications menu.

  --local  Allow launch from the physical NetBSD console. A separate SSH
           recovery login remains strongly recommended.

During takeover, Ctrl+Alt+F1 through F12 request the corresponding configured
VT. Ctrl+Alt+Backspace requests emergency session termination and console
restoration below the desktop core and focused applications.

Environment:
  NIXBENCH_APPLICATION      Absolute executable to open at startup
  NIXBENCH_GTK_MENU_BRIDGE  Export GTK3 application menus (default: 1)
  NIXBENCH_XWAYLAND_ROOTLESS Start the rootless X11 compatibility service
                            when Xwayland is installed (default: 1)
  NIXBENCH_XWAYLAND          Override the absolute Xwayland executable path
  NIXBENCH_XWAYLAND_LEGACY_ASSOCIATION
                            Use the legacy surface-ID association path
                            for troubleshooting (default: 0)
  NIXBENCH_VT_AWAY          One-based VT used by the lifecycle test
EOF
        exit 0
        ;;
    --local)
        local_launch=1
        ;;
    '') ;;
    *)
        echo "nixbench-session: usage: nixbench-session [--local]" >&2
        exit 2
        ;;
esac

program=$0
case "$program" in
    */*) ;;
    *)
        program=$(command -v "$program") || {
            echo "nixbench-session: could not locate installed command" >&2
            exit 1
        }
        ;;
esac
while [ -L "$program" ]; do
    directory=$(CDPATH= cd "$(dirname "$program")" && pwd)
    target=$(readlink "$program") || exit 1
    case "$target" in
        /*) program=$target ;;
        *) program=$directory/$target ;;
    esac
done
bindir=$(CDPATH= cd "$(dirname "$program")" && pwd)
prefix=$(CDPATH= cd "$bindir/.." && pwd)
libexecdir='@CMAKE_INSTALL_LIBEXECDIR@'
case "$libexecdir" in
    /*) ;;
    *) libexecdir=$prefix/$libexecdir ;;
esac

NIXBENCH_INSTALLED_MODE=1
NIXBENCH_SESSION_HELPER=$libexecdir/nixbench/nixbench-wsdisplay-session
NIXBENCH_SESSION_CORE=$libexecdir/nixbench/nixbench-session-core
NIXBENCH_GTK_MENU_BRIDGE=${NIXBENCH_GTK_MENU_BRIDGE:-1}
NIXBENCH_XWAYLAND_ROOTLESS=${NIXBENCH_XWAYLAND_ROOTLESS:-1}
NIXBENCH_XWAYLAND_LEGACY_ASSOCIATION=${NIXBENCH_XWAYLAND_LEGACY_ASSOCIATION:-0}
NIXBENCH_ALLOW_LOCAL=$local_launch
export NIXBENCH_INSTALLED_MODE NIXBENCH_SESSION_HELPER
export NIXBENCH_SESSION_CORE NIXBENCH_GTK_MENU_BRIDGE
export NIXBENCH_XWAYLAND_ROOTLESS NIXBENCH_ALLOW_LOCAL
export NIXBENCH_XWAYLAND_LEGACY_ASSOCIATION

exec "$libexecdir/nixbench/run-wsdisplay-session.sh"
